# Required: Twilio Account SID
TWILIO_ACCOUNT_SID=

# Option A: API Key (preferred)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Option B: Auth Token (if not using API key)
TWILIO_AUTH_TOKEN=

# Comma-separated list of allowed origins for /api/twilio (no trailing slash).
# Example: https://your-app.vercel.app,https://yourdomain.com
# Leave blank in local dev — localhost is allowed by default.
ALLOWED_ORIGINS=
